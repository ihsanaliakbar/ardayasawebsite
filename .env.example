# Copy to .env and fill in. Used by docker-compose; the API also reads these
# as environment variables when run outside compose.

# --- PostgreSQL ---
POSTGRES_DB=ardayasa
POSTGRES_USER=ardayasa
POSTGRES_PASSWORD=change-me-strong-password

# Connection string for the API (compose overrides host to the postgres service)
ConnectionStrings__Default=Host=localhost;Port=5432;Database=ardayasa;Username=ardayasa;Password=change-me-strong-password

# --- Seeded admin (created on first run if missing) ---
ADMIN_EMAIL=admin@ardayasa.local
ADMIN_PASSWORD=change-me-strong-password
ADMIN_FULL_NAME=Admin Ardayasa

# --- JWT ---
Jwt__Issuer=ardayasa
Jwt__Audience=ardayasa-web
# 256-bit+ random secret, e.g. `openssl rand -base64 48`
Jwt__SigningKey=change-me-random-256-bit-secret
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30

# --- Google OAuth (leave empty until provided; Google login stays disabled) ---
Google__ClientId=
Google__ClientSecret=

# --- Email (SMTP via MailKit). Empty host => dev stub that logs emails. ---
Smtp__Host=
Smtp__Port=587
Smtp__Username=
Smtp__Password=
Smtp__FromAddress=no-reply@ardayasa.local
Smtp__FromName=Ardayasa Wellbeing and Growth Center

# --- WhatsApp (Fonnte). Empty token => dev stub that logs messages. ---
Fonnte__ApiToken=

# --- File storage ---
FileStorage__RootPath=/app/storage

# --- Frontend ---
# Public origin of the Angular app (CORS + links in emails)
App__WebBaseUrl=http://localhost:4200
